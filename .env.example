# Root environment values shared by the monorepo.
# FastAPI loads this file automatically from the repo root.
# Vite reads it because client/vite.config.ts points envDir at the monorepo root.

APP_NAME=ghostline
APP_ENV=development
LOG_LEVEL=INFO

CLIENT_HOST=127.0.0.1
CLIENT_PORT=5173
VITE_SESSION_WS_URL=ws://127.0.0.1:8000/ws/session

SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-live-2.5-flash-native-audio
# Keep the credential JSON outside this repo when possible and store only its path here.
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_LIVE_VOICE_NAME=
GEMINI_LIVE_VOICE_LANGUAGE_CODE=en-US
GEMINI_LIVE_INPUT_TRANSCRIPTION=true
GEMINI_LIVE_OUTPUT_TRANSCRIPTION=true

# Prompt 22 temporary development-only verifier.
# TODO(Prompt 23): disable and remove this when the real verifier is wired in.
MOCK_VERIFICATION_ENABLED=false
MOCK_VERIFICATION_FORCE_FAILURE=false
MOCK_VERIFICATION_TIER1_RESULT=confirmed
MOCK_VERIFICATION_TIER2_RESULT=user_confirmed_only
MOCK_VERIFICATION_TIER3_RESULT=user_confirmed_only
MOCK_VERIFICATION_UNKNOWN_TIER_RESULT=user_confirmed_only

FIRESTORE_DATABASE=(default)
FIRESTORE_SESSIONS_COLLECTION=ghostline_sessions
CLOUD_RUN_SERVICE=
