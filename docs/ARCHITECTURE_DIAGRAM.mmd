flowchart LR
    caller["Caller / Room"]

    subgraph client["Frontend Hotline UI (React + Vite + TypeScript)"]
        ui["Ghostline hotline shell\nOperator panel\nGrounding HUD\nTranscript layer\nTask controls\nCase report view"]
        media["Camera + mic capture\nStaged frame sampler\nOperator audio playback\nAmbient sound layer"]
        wsClient["Client WebSocket session bridge"]
        demo["Demo mode + rehearsal harness"]
    end

    subgraph cloudrun["Cloud Run Service"]
        subgraph backend["FastAPI Backend"]
            gateway["WebSocket gateway\n/healthz /readyz\n/ops/proof/active-session"]
            bridge["Gemini Live audio bridge\nPCM input/output\nBarge-in flush"]
            state["Authoritative session state machine"]
            planner["Deterministic planner\nTask library\nRecovery ladders\nFlavor + diagnosis state"]
            verifier["Ready-to-Verify flow\nTask-aware verifier\nCase report generator"]
        end
    end

    subgraph google["Google Cloud Services"]
        vertex["Vertex AI / Gemini Live\nRealtime voice + transcription"]
        firestore["Firestore\nSession snapshots\nCase report persistence"]
        logs["Cloud Logging\nStructured proof events"]
    end

    caller -->|"voice, room, camera framing"| media
    media --> ui
    demo --> ui
    ui --> wsClient
    media --> wsClient
    wsClient <-->|"session envelopes\naudio chunks\nframes\ntranscripts\nstate snapshots"| gateway

    gateway --> bridge
    gateway --> state
    state --> planner
    state --> verifier
    planner --> state
    verifier --> state
    bridge --> state

    bridge <-->|"live audio + transcripts"| vertex
    state -->|"session snapshots\nproof fields\ncase report"| firestore
    gateway -->|"session events"| logs
    bridge -->|"Gemini lifecycle\ninterruption events"| logs
    state -->|"task, verification, recovery, report"| logs

    state --> gateway
    verifier --> gateway
    bridge --> gateway

