flowchart LR
    caller["Caller / Room"]
    deploy["Repo + deploy-cloud-run.ps1\nEnvironment-driven backend deploy"]

    subgraph client["Frontend Hotline UI (React + Vite + TypeScript)"]
        splash["Two-mode splash\nLaunch Demo Mode / Launch Regular Mode"]
        ui["Ghostline shell\nTranscript\nGrounding HUD\nTask controls\nCase report"]
        media["Camera + mic capture\nRoom scan frames\nTask vision frames\nOperator audio playback"]
        wsClient["Client WebSocket session bridge"]
        demo["Demo mode fixed path"]
    end

    subgraph google["Google Cloud Services"]
        build["Cloud Build + Artifact Registry\nContainer build and image storage"]

        subgraph cloudrun["Cloud Run Service"]
            subgraph backend["FastAPI Backend (Google GenAI SDK)"]
                gateway["WebSocket gateway\n/readyz\n/ops/proof/active-session"]
                bridge["Gemini Live audio bridge\nAudio streaming\nImage frame delivery\nBarge-in flush"]
                state["Authoritative session state machine\nSetup + task progression"]
                planner["Protocol planner\nTask library\nRecovery ladders"]
                vision["Verification flow\nGemini-based + deterministic checks"]
                report["Case report generation"]
            end
        end

        vertex["Vertex AI / Gemini Live\nRealtime voice + vision + transcription"]
        logs["Cloud Logging\nStructured operational events\nsession_id proof queries"]
    end

    caller -->|"voice, room, camera framing"| media
    deploy --> build
    build --> cloudrun
    splash --> ui
    demo --> ui
    media --> ui
    ui --> wsClient
    media --> wsClient
    wsClient <-->|"session envelopes\naudio chunks\nroom/task/verify frames\ntranscripts\nstate snapshots"| gateway

    gateway --> bridge
    gateway --> state
    state --> planner
    state --> vision
    vision --> report
    bridge --> state
    planner --> state
    vision --> state

    bridge <-->|"live audio + image frames"| vertex
    gateway -->|"session events"| logs
    bridge -->|"Gemini lifecycle events"| logs
    state -->|"state transitions"| logs
    vision -->|"verification events"| logs

